rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Helper function to check if the user is an Admin
    function isAdmin() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 2. Rules for the USERS collection
    match /users/{userId} {
      // Users can read and edit their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Admins can see and edit all users for the registry
      allow read, write: if isAdmin();
    }

    // 3. Rules for the PREDICTIONS (Intelligence Feed) collection
    match /predictions/{predictionId} {
      // Authenticated users can view predictions for the charts
      allow read: if request.auth != null;
      // ONLY Admins can add or update prediction data
      allow write: if isAdmin();
    }

    // 4. Default deny (Security best practice) [cite: 2026-01-21]
    match /{document=**} {
      allow read, write: if false;
    }
  }
}